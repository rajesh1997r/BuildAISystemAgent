# ── Required ───────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Optional: model override ───────────────────────────────────────────────
# Default is gpt-4o-mini (fast, affordable).  Use gpt-4o for best quality.
OPENAI_MODEL_NAME=gpt-4o-mini

# ── Optional: Serper web search (alternative to DuckDuckGo) ───────────────
# Only needed if you replace WebSearchTool with SerperDevTool
# SERPER_API_KEY=your-serper-api-key-here
